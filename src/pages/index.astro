---
import { readdirSync } from "node:fs";
import { resolve } from "node:path";
import "../styles/global.css";

const pageTitle = "1896 Brand Induction";
const productCollectionsLink = "https://www.eighteen96.co.za/collections";
const productReferenceLinks = [
  {
    label: "Browse 1896 Collections",
    href: productCollectionsLink,
  },
];
const sectionNav = [
  { href: "#welcome", label: "Welcome" },
  { href: "#who-we-are", label: "Who We Are" },
  { href: "#what-we-offer", label: "What We Offer" },
  { href: "#living-the-brand", label: "Living 1896" },
  { href: "#closing", label: "Closing" },
];

const videoLessons = [
  {
    id: "brand-story-video",
    title: "Our Brand Story",
    fileName: "2. 1896 Brand Story (3).mp4",
    intro:
      "1896 is about modern luxury grounded in meaning. Our jewellery is designed to be worn and lived in, not kept aside. It represents moments and personal stories.",
    meaning:
      "Watch the video to understand our brand story.",
  },
  {
    id: "time-and-craft-video",
    title: "Luxury as Time and Craft",
    fileName: "3. Luxury as time & Craft.mp4",
    intro:
      "The value of a piece is not only in how it looks, but in the time, care, and craftsmanship behind it. Watch the video to learn more.",
    meaning: "",
  },
  {
    id: "luxury-journey-video",
    title: "The Luxury Journey",
    fileName: "4. The Luxury Journey.mp4",
    intro:
      "Luxury is experienced in how a piece is handled, presented, and shared. Watch the video to learn more.",
    meaning: "",
  },
];

const productExplorationSteps = [
  "Explore the website and select one collection and one piece.",
  "Observe what stands out and the feeling it creates.",
  "Consider the meaning behind the piece.",
  "Connect it to a customer and a moment.",
  "Describe it simply in 1-2 sentences.",
  "Practise storytelling with a colleague.",
];

const knowledgeCheckLesson3 = {
  promptLead: "A customer says:",
  promptQuote: '"I want something special... I just don\'t want it to feel over the top."',
  promptTail: "What would you say next?",
  options: [
    {
      id: "A",
      text: '"Then you should look at our rarest options - that is what makes it special."',
    },
    {
      id: "B",
      text:
        '"Tell me a bit about the moment - and how you\'d like to wear the piece - then I\'ll show you a few options that fit."',
    },
    {
      id: "C",
      text: '"Let\'s start with the newest pieces - those are usually the best choice."',
    },
    {
      id: "D",
      text: '"If it must be special, the higher the price, the better."',
    },
  ],
  answer: "B",
  feedback:
    'At 1896, "special" is not only about price or rarity - it is about meaning, and how the piece fits the customer\'s life.',
};

const servicePillars = [
  {
    title: "Warmth and Respect",
    detail: "Give the customer space and match their pace.",
  },
  {
    title: "Professionalism with Personality",
    detail: "Be polished, while remaining natural and human.",
  },
  {
    title: "Customer-led Experience",
    detail: "Let the customer guide the interaction, and respond to what matters to them.",
  },
  {
    title: "Storytelling and Expertise",
    detail: "Connect each piece to meaning, not just features.",
  },
  {
    title: "Safety and Comfort",
    detail: "Create a calm, considered environment for the customer.",
  },
  {
    title: "Creativity and Style",
    detail: "Adapt your approach to the individual and the moment.",
  },
  {
    title: "Digital Engagement",
    detail: "Extend the experience beyond the store in a way that feels personal and considered.",
  },
];

const knowledgeChecksLesson4 = [
  {
    prompt:
      'A customer is browsing quietly and says, "I\'m just looking." What\'s the best next step?',
    options: [
      "A) Start explaining the full range.",
      "B) Give them space and check back gently.",
      "C) Ask about their budget immediately.",
    ],
    answer: "B",
    feedback:
      "A 1896 experience is customer-led. We respect the customer's pace and allow the conversation to unfold naturally.",
  },
  {
    prompt:
      'A customer asks, "What makes 1896 different?" Which response is most aligned with the brand?',
    options: [
      "A) We have higher quality and more exclusive products.",
      "B) We've been around longer than most brands.",
      "C) We focus on helping you choose a piece that fits your life and the moment you are celebrating.",
    ],
    answer: "C",
    feedback:
      "1896 is differentiated by <strong>how we connect jewellery to meaning</strong>, not by listing features or making comparisons.",
  },
];

const mediaDir = resolve(process.cwd(), "public", "media");
const mediaEntries = readdirSync(mediaDir).sort((a, b) => a.localeCompare(b));
const toMediaUrl = (fileName) => `/media/${fileName}`;

const videoFiles = mediaEntries.filter((name) => /\.mp4$/i.test(name));
const mediaByName = new Map(mediaEntries.map((name) => [name.toLowerCase(), name]));
const pickMedia = (name) => {
  const match = mediaByName.get(name.toLowerCase());
  return match ? toMediaUrl(match) : "";
};

const tfgLogo = "/tfg-logo.svg";
const logoDark = "";
const logoLight = pickMedia("_1896 W_Logo.png");

const findVideoSource = (targetName) => {
  const match = videoFiles.find((name) => name.toLowerCase() === targetName.toLowerCase());
  return match ? toMediaUrl(match) : "";
};

const findVideoSourceForLesson = (lessonIndex, fallbackName) => {
  const preferredPrefix = `video ${lessonIndex + 1}`.toLowerCase();
  const preferred = videoFiles.find((name) => name.toLowerCase().startsWith(preferredPrefix));
  if (preferred) return toMediaUrl(preferred);
  return findVideoSource(fallbackName);
};

const curatedImageNames = {
  hero: "banner.jpg",
  videoPosters: [
    "20260506_090539752_iOS.jpeg",
    "20260506_101332680_iOS.jpeg",
    "20260506_122416453_iOS.jpeg",
  ],
};

const heroImage = pickMedia(curatedImageNames.hero);
const curatedVideoPosters = curatedImageNames.videoPosters.map((name) => pickMedia(name));

const videos = videoLessons.map((video, index) => ({
  ...video,
  src: findVideoSourceForLesson(index, video.fileName),
  poster: curatedVideoPosters[index] || "",
}));

const servicePillarVisual = pickMedia("20260506_113656197_iOS.jpeg");
const knowledgeCheckCustomerImage = pickMedia("20260506_101955367_iOS.jpeg");
const closingFocusStatements = [
  "How you listen.",
  "How you present a piece.",
  "How you guide the conversation.",
];
const servicePillarsBackground = pickMedia("20260506_120130684_iOS.jpeg");
const exploreProductsBackground = pickMedia("20260506_112532376_iOS.jpeg");
const exploreProductsVisual = pickMedia("20260506_112452061_iOS.jpeg");
const naturalHighlightImage = pickMedia("earth-grown.jpg");
const labGrownHighlightImage = pickMedia("lab-grown.jpg");
const watchesHighlightImage = pickMedia("watches.jpg");
const productHighlights = [
  {
    title: "Natural Diamonds",
    image: naturalHighlightImage,
  },
  {
    title: "Lab-grown Diamonds",
    image: labGrownHighlightImage,
  },
  {
    title: "High-end Watches",
    image: watchesHighlightImage,
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <style is:global>
      :root {
        --b-ink: #000000;
        --b-paper: #ffffff;
        --b-stone: #ece9e2;
        --b-cream: rgb(239 230 218);
        --b-sage: #adbeaf;
        --b-sage-solid: rgb(166 188 177);
        --b-sage-soft: #cfdccf;
        --b-sage-fog: #e2ebe1;
        --b-champagne: #c8a98a;
        --b-muted: #6f6257;
      }
    </style>
  </head>

  <body class="bg-[#fff] text-black selection:bg-[#d6c2aa] selection:text-black">
    <main class="mx-auto max-w-[1240px] px-3 py-5 md:px-8 md:py-10">
      <header class="sticky top-3 z-40 rounded-[0.9rem] border border-[#dce1da] bg-white/95 px-3 py-3 shadow-[0_10px_26px_rgba(56,37,24,0.05)] backdrop-blur md:px-6">
        <div class="flex items-center justify-between gap-3 md:hidden">
          <div class="flex min-w-0 items-center gap-3">
            <img src={tfgLogo} alt="TFG logo" class="h-10 w-10 shrink-0 object-cover" />
            <p class="min-w-0 text-sm font-medium leading-5 text-black">{pageTitle}</p>
          </div>

          <details class="relative shrink-0 md:hidden" data-mobile-nav>
            <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-[#dce1da] bg-[#f8f7f5] text-black transition hover:bg-[#edf1ec] [&::-webkit-details-marker]:hidden">
              <span class="sr-only">Toggle lesson navigation</span>
              <span aria-hidden="true" class="flex flex-col gap-[0.28rem]">
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
              </span>
            </summary>
            <div class="absolute right-0 top-[calc(100%+0.75rem)] z-20 w-64 max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-[0.9rem] border border-[#dce1da] bg-white p-2 shadow-[0_14px_36px_rgba(56,39,27,0.09)]">
              <div class="flex flex-col gap-1.5 text-sm text-black">
                {sectionNav.map((item) => (
                  <a href={item.href} class="rounded-[0.75rem] px-4 py-3 transition hover:bg-[#edf1ec]" data-mobile-nav-link>{item.label}</a>
                ))}
              </div>
            </div>
          </details>
        </div>

        <div class="hidden md:flex md:items-center md:justify-between md:gap-6">
          <div class="flex items-center gap-4">
            <img src={tfgLogo} alt="TFG logo" class="h-10 w-10 object-cover" />
            <p class="text-sm font-medium text-black">{pageTitle}</p>
          </div>
          <div class="flex flex-wrap gap-2 text-sm text-black">
            {sectionNav.map((item) => (
              <a href={item.href} class="rounded-full border border-[#dce1da] bg-[#f8f7f5] px-4 py-2 transition hover:bg-[#edf1ec]">{item.label}</a>
            ))}
          </div>
        </div>
      </header>

      <section id="welcome" class="relative mt-6 scroll-mt-28">
        <div class="relative overflow-hidden rounded-[1rem] bg-[var(--b-cream)]">
          {heroImage && (
              <img
                src={heroImage}
                alt=""
                class="pointer-events-none absolute inset-0 h-full w-full object-cover scale-[1.03]"
                loading="eager"
              />
          )}
          <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(160deg,rgba(18,14,10,0.46)_0%,rgba(18,14,10,0.3)_42%,rgba(18,14,10,0.58)_100%)]"></div>
          <div class="relative px-5 py-14 md:px-12 md:py-20 lg:px-14 lg:py-24">
            <div class="mx-auto max-w-4xl text-center">
              {logoLight || logoDark ? (
                <img src={logoLight || logoDark} alt="1896 logo" class="mx-auto h-10 w-auto object-contain md:h-12" />
              ) : (
                <span class="text-sm font-semibold tracking-[0.14em] text-white">1896</span>
              )}

              <h1 class="mt-10 text-4xl font-medium uppercase tracking-[0.08em] text-white md:mt-12 md:text-6xl">Welcome to 1896</h1>
              <div class="mx-auto mt-6 h-px w-16 bg-[rgba(255,244,230,0.82)]"></div>
            </div>
          </div>
        </div>

        <div id="lesson-1" class="mt-14 space-y-8">
          <div class="px-1 md:px-2">
            <h2 class="text-[2rem] font-medium uppercase tracking-[0.08em] text-black md:text-[2.45rem]">Welcome</h2>
          </div>

          <article class="overflow-hidden rounded-[1rem] bg-[var(--b-cream)] shadow-[0_14px_36px_rgba(56,39,27,0.05)]">
            <div class="space-y-7 px-5 py-7 md:px-10 md:py-11">
              <div class="space-y-5 text-[1.02rem] leading-8 text-black">
                <p><b>Welcome to the 1896 Brand Induction.</b></p>
                <p>
                  This introduction introduces who we are as a brand, what we stand for, and what it means to
                  represent 1896 in-store.
                </p>
                <p>
                  You'll learn about the story behind 1896, how we think about luxury, and how this shapes the
                  way we engage with customers.
                </p>
                <p>As you go through this induction, focus on how each idea would show up in a real interaction.</p>
              </div>

              <div>
                <a
                  href="#who-we-are"
                  class="inline-flex items-center rounded-full bg-[#1f1a16] px-5 py-3 text-sm font-semibold uppercase tracking-[0.14em] text-[#f7f1e8] shadow-[0_10px_24px_rgba(31,26,22,0.22)] transition hover:bg-[#000000]"
                >
                  Start the journey
                </a>
              </div>
            </div>
          </article>
        </div>
      </section>

      <section id="who-we-are" class="mt-14 space-y-8 border-t border-[#e8e2d8] pt-10 scroll-mt-28">
        <div class="px-1 md:px-2">
          <h2 class="text-[2rem] font-medium uppercase tracking-[0.08em] text-black md:text-[2.45rem]">Who We Are</h2>
        </div>

        <div class="space-y-5">
          {videos.map((video) => (
            <article id={video.id} class="overflow-hidden rounded-[1rem] bg-[var(--b-sage-soft)] shadow-[0_14px_36px_rgba(56,39,27,0.05)]">
              <div class="space-y-7 px-5 py-7 md:px-10 md:py-11">
                <div>
                  <h3 class="text-[1.6rem] font-semibold leading-[1.15] tracking-[-0.02em] text-black md:text-[2rem]">
                    {video.title}
                  </h3>
                </div>

                <div class="space-y-4 text-[1.02rem] leading-8 text-black">
                  <p>{video.intro}</p>
                  {video.meaning && <p>{video.meaning}</p>}
                </div>

                <div class="overflow-hidden rounded-[0.95rem] border border-[#d8cfc6] bg-[#f8f4f0]">
                  {video.src ? (
                    <video
                      class="aspect-video h-full w-full bg-[#1a1613] object-cover"
                      controls
                      preload="metadata"
                      poster={video.poster || undefined}
                    >
                      <source src={video.src} type="video/mp4" />
                      Your browser does not support the video tag.
                    </video>
                  ) : (
                    <div class="flex aspect-video items-center justify-center bg-[linear-gradient(135deg,#ece2d8_0%,#d6c0ab_100%)]">
                      <div class="text-center">
                        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-black">Video Placeholder</p>
                        <p class="mt-3 text-sm text-black">{video.fileName}</p>
                      </div>
                    </div>
                  )}
                </div>

              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="what-we-offer" class="mt-14 space-y-8 border-t border-[#e8e2d8] pt-10 scroll-mt-28">
        <div class="px-1 md:px-2">
          <h2 class="text-[2rem] font-medium uppercase tracking-[0.08em] text-black md:text-[2.45rem]">What We Offer</h2>
          <p class="mt-6 max-w-5xl text-[1.08rem] leading-9 text-black">
            1896 is a modern luxury jewellery brand rooted in heritage. We focus on meaning, not just exclusivity - often expressed as resonance over rarity. Customers choose a piece for what it represents - not only what it is.
          </p>
        </div>

        <article class="rounded-[1rem] bg-[var(--b-cream)] p-5 shadow-[0_14px_36px_rgba(56,39,27,0.05)] md:p-8">
          <p class="max-w-4xl text-[1.02rem] leading-8 text-black">
            1896 includes natural diamonds, lab-grown diamonds, and high-end watches. Your role is not to promote one over another. It is to guide the choice based on the customer and the moment.
          </p>
          <div class="mt-6 grid gap-4 md:grid-cols-3">
            {productHighlights.map((highlight) => (
              <article class="overflow-hidden rounded-[0.95rem] border border-[#d9cec1] bg-white shadow-[0_12px_28px_rgba(54,35,24,0.08)]">
                <div class="aspect-square overflow-hidden bg-[#f3ebe3]">
                  {highlight.image ? (
                    <img
                      src={highlight.image}
                      alt={highlight.title}
                      class="h-full w-full object-contain"
                      loading="lazy"
                    />
                  ) : (
                    <div class="flex h-full items-center justify-center bg-[linear-gradient(135deg,#f2e7db_0%,#dec8b2_100%)] text-sm font-semibold uppercase tracking-[0.14em] text-[#705946]">
                      Add image
                    </div>
                  )}
                </div>
                <div class="border-t border-[#d9cec1] bg-[#e7d9cb] px-4 py-3">
                  <p class="text-center text-[1.02rem] font-semibold tracking-[0.01em] text-black">{highlight.title}</p>
                </div>
              </article>
            ))}
          </div>
        </article>

        <div class="grid gap-5 lg:grid-cols-[0.55fr_0.45fr]">
          <article class="relative overflow-hidden rounded-[1rem] bg-[#c2d3c7] p-5 shadow-[0_14px_36px_rgba(56,39,27,0.08)] md:p-8">
            {exploreProductsBackground && (
              <>
                <img
                  src={exploreProductsBackground}
                  alt=""
                  class="pointer-events-none absolute inset-0 h-full w-full scale-[1.03] object-cover opacity-[0.44]"
                  loading="lazy"
                />
                <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(145deg,rgba(246,252,246,0.74)_0%,rgba(226,238,231,0.64)_45%,rgba(194,212,201,0.74)_100%)]"></div>
              </>
            )}
            <div class="relative z-10">
              <h3 class="text-[1.35rem] font-semibold tracking-[-0.015em] text-black">Explore Our Products</h3>
              <p class="mt-4 text-[1.02rem] leading-8 text-black">
                Take a short moment to explore the 1896 range. This helps connect product, meaning, and conversation.
              </p>
              <div class="mt-6 grid gap-3">
                {productReferenceLinks.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noreferrer"
                    class="group rounded-[0.9rem] border border-[#b7c7bb] bg-white/80 px-4 py-4 shadow-[0_10px_24px_rgba(46,33,25,0.1)] transition hover:-translate-y-[1px] hover:bg-white hover:shadow-[0_14px_30px_rgba(46,33,25,0.14)]"
                  >
                    <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[#294034]">{link.label}</p>
                    <p class="mt-1 break-all text-sm text-black underline decoration-[#86a18f] decoration-[1.8px] underline-offset-4">{link.href}</p>
                  </a>
                ))}
              </div>

              {exploreProductsVisual && (
                <figure class="relative mt-6 overflow-hidden rounded-[0.98rem] border border-[#b6c7ba] bg-white/42 shadow-[0_12px_28px_rgba(44,33,24,0.1)]">
                  <img src={exploreProductsVisual} alt="1896 product exploration visual" class="h-72 w-full object-cover md:h-80 lg:h-96" loading="lazy" />
                  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(170deg,rgba(20,14,11,0.12)_0%,rgba(20,14,11,0.42)_100%)]"></div>
                </figure>
              )}

              <div class="mt-6 space-y-4">
                {productExplorationSteps.map((step, index) => (
                  <article class="rounded-[0.8rem] border border-[#bfd0c3] bg-white/62 px-4 py-3 backdrop-blur-[1px]">
                    <div class="flex items-start gap-3">
                      <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[#b8cabe] bg-[#edf3ed] text-[0.72rem] font-semibold text-[#294034]">
                        {index + 1}
                      </span>
                      <p class="pt-0.5 text-[1.02rem] leading-7 text-black">{step}</p>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </article>

          <article class="rounded-[1rem] bg-white/88 p-5 shadow-[0_14px_36px_rgba(56,39,27,0.05)] md:p-8">
            <div class="space-y-5">
              <div class="rounded-[0.95rem] border border-[#d8e0d8] bg-[#f0f4f0] p-5">
                <p class="text-sm font-semibold uppercase tracking-[0.17em] text-black">In-store application</p>
                <ul class="mt-4 list-disc space-y-3 pl-5 text-[1.02rem] leading-8 text-black marker:text-black">
                  <li>Choose a piece.</li>
                  <li>Notice how it feels and sits.</li>
                  <li>Practise describing it simply and naturally to a colleague.</li>
                </ul>
              </div>

              <div class="rounded-[0.95rem] border border-[#d8e0d8] bg-[#f0f4f0] p-5">
                <div class="flex items-center gap-3">
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-[#cdb89f] bg-[#f8f1e8] text-[#735c47]">
                    <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.1">
                      <circle cx="10" cy="10" r="6.2" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M7.8 10.2 9.4 11.8 12.4 8.7" />
                    </svg>
                  </span>
                  <p class="text-sm font-semibold uppercase tracking-[0.17em] text-black">Check yourself:</p>
                </div>
                <ul class="mt-4 list-disc space-y-3 pl-5 text-[1.02rem] leading-8 text-black marker:text-black">
                  <li>Did you focus on meaning?</li>
                  <li>Did you keep the language natural?</li>
                  <li>Could you connect to the real moment?</li>
                </ul>
              </div>
            </div>
          </article>
        </div>

        <article class="rounded-[1rem] bg-white/88 p-5 shadow-[0_14px_36px_rgba(56,39,27,0.05)] md:p-8">
          <div class="flex items-center gap-3">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-[#cdb89f] bg-[#f8f1e8] text-[#735c47]">
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.1">
                <circle cx="10" cy="10" r="6.2" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.8 10.2 9.4 11.8 12.4 8.7" />
              </svg>
            </span>
            <p class="text-sm font-semibold uppercase tracking-[0.17em] text-black">Knowledge Check</p>
          </div>
          <div class="mt-4 grid gap-4 md:grid-cols-[1.05fr_0.95fr] md:items-start">
            {knowledgeCheckCustomerImage && (
              <figure class="overflow-hidden rounded-[0.82rem] border border-[#d9cec0] bg-[#f7efe5] md:order-2 md:justify-self-end">
                <img src={knowledgeCheckCustomerImage} alt="Customer in-store moment" class="h-56 w-full object-cover md:h-full md:min-h-[14rem]" loading="lazy" />
              </figure>
            )}
            <div class={knowledgeCheckCustomerImage ? "md:order-1" : "md:col-span-2"}>
              <p class="text-[1.02rem] leading-8 text-black">Let's pause for a moment.</p>
              <p class="mt-4 text-[1.02rem] leading-8 text-black">
                {knowledgeCheckLesson3.promptLead} <span class="font-semibold">{knowledgeCheckLesson3.promptQuote}</span> {knowledgeCheckLesson3.promptTail}
              </p>
              <div
                class="mt-5 space-y-3"
                data-kc3-options
                data-kc3-answer={knowledgeCheckLesson3.answer}
                data-kc3-feedback-copy={knowledgeCheckLesson3.feedback}
              >
                {knowledgeCheckLesson3.options.map((option) => (
                  <button
                    type="button"
                    class="tfg-quiz-option w-full rounded-[0.75rem] border border-[#dacbbb] bg-[#f7f0e6] px-4 py-3 text-left text-black transition hover:bg-[#f3e8da]"
                    data-kc3-option={option.id}
                    data-kc3-correct={option.id === knowledgeCheckLesson3.answer ? "true" : "false"}
                    data-kc3-state="idle"
                  >
                    <span class="font-semibold">{option.id})</span> {option.text}
                  </button>
                ))}
              </div>
              <p class="mt-4 hidden rounded-[0.75rem] border px-4 py-3 text-[1.02rem] leading-8" data-kc3-feedback></p>
            </div>
          </div>
        </article>
      </section>

      <section id="living-the-brand" class="mt-14 space-y-8 border-t border-[#e8e2d8] pt-10 scroll-mt-28">
        <div class="px-1 md:px-2">
          <h2 class="text-[2rem] font-medium uppercase tracking-[0.08em] text-black md:text-[2.45rem]">Living the 1896 Brand</h2>
          <p class="mt-6 max-w-5xl text-[1.08rem] leading-9 text-black">
            At 1896, the brand is experienced through behaviour. How a customer is welcomed, how jewellery is handled,
            and how conversations are paced all shape the experience.
          </p>
        </div>

        <div class="grid gap-5 lg:grid-cols-[0.55fr_0.45fr]">
          <article class="relative overflow-hidden rounded-[1rem] bg-[#c2d3c7] p-5 shadow-[0_14px_36px_rgba(56,39,27,0.08)] md:p-8">
            {servicePillarsBackground && (
              <>
                <img
                  src={servicePillarsBackground}
                  alt=""
                  class="pointer-events-none absolute inset-0 h-full w-full scale-[1.03] object-cover opacity-[0.44]"
                  loading="lazy"
                />
                <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(145deg,rgba(246,252,246,0.74)_0%,rgba(226,238,231,0.64)_45%,rgba(194,212,201,0.74)_100%)]"></div>
              </>
            )}
            <div class="relative z-10">
              <h3 class="text-[1.35rem] font-semibold tracking-[-0.015em] text-black">Service Pillars</h3>
              <p class="mt-4 text-[1.02rem] leading-8 text-black">These pillars guide how the experience should feel - not what should be said.</p>

              {servicePillarVisual && (
                <figure class="relative mt-6 overflow-hidden rounded-[0.98rem] border border-[#b6c7ba] bg-white/42 shadow-[0_12px_28px_rgba(44,33,24,0.1)]">
                  <img src={servicePillarVisual} alt="1896 in-store and product visual" class="h-72 w-full object-cover md:h-80 lg:h-96" loading="lazy" />
                  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(170deg,rgba(20,14,11,0.12)_0%,rgba(20,14,11,0.42)_100%)]"></div>
                </figure>
              )}

              <div class="mt-6 space-y-4">
                {servicePillars.map((pillar) => (
                  <details class="tfg-accordion group rounded-[0.8rem] border border-[#bfd0c3] bg-white/62 px-4 py-3 backdrop-blur-[1px]" data-service-pillar>
                    <summary class="cursor-pointer list-none text-black font-semibold [&::-webkit-details-marker]:hidden">
                      <span class="flex items-center justify-between gap-3">
                        {pillar.title}
                        <span class="text-black transition group-open:rotate-45">+</span>
                      </span>
                    </summary>
                    <div class="tfg-accordion-content">
                      <div class="overflow-hidden">
                        <p class="pt-4 text-[1.02rem] leading-8 text-black">{pillar.detail}</p>
                      </div>
                    </div>
                  </details>
                ))}
              </div>
            </div>
          </article>

          <article class="rounded-[1rem] bg-white/88 p-5 shadow-[0_14px_36px_rgba(56,39,27,0.05)] md:p-8">
            <div class="flex items-center gap-3">
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-[#c6d2c4] bg-[#eef3ee] text-[#506452]">
                <svg viewBox="0 0 20 20" class="h-4.5 w-4.5" fill="none" stroke="currentColor" stroke-width="1.1">
                  <circle cx="10" cy="10" r="6.2" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.8 10.2 9.4 11.8 12.4 8.7" />
                </svg>
              </span>
              <h3 class="text-[1.35rem] font-semibold tracking-[-0.015em] text-black">Knowledge Check</h3>
            </div>
            <div class="mt-5 space-y-5">
              {knowledgeChecksLesson4.map((check, checkIndex) => (
                <div class="border-t border-[#d8e0d8] pt-5 first:border-t-0 first:pt-0">
                  <p class="text-[1.02rem] leading-8 text-black">{check.prompt}</p>
                  <div class="mt-4 space-y-3">
                    {check.options.map((option, optionIndex) => (
                      <button
                        type="button"
                        class="tfg-quiz-option w-full rounded-[0.72rem] border border-[#bfd0c3] bg-[#f0f4f0] px-4 py-3 text-left text-black transition hover:bg-white/95"
                        data-l4-option={optionIndex}
                        data-l4-question={checkIndex}
                        data-l4-correct={String.fromCharCode(65 + optionIndex) === check.answer ? "true" : "false"}
                        data-kc3-state="idle"
                      >
                        {option}
                      </button>
                    ))}
                  </div>
                  <p class="mt-4 hidden rounded-[0.8rem] border px-4 py-3 text-[1.02rem] leading-8" data-l4-feedback={checkIndex}>
                    The best answer is <span class="font-semibold">{check.answer}</span>. <span set:html={check.feedback}></span>
                  </p>
                </div>
              ))}
            </div>
          </article>
        </div>

      </section>

      <section id="closing" class="mt-10 scroll-mt-28">
        <article class="overflow-hidden rounded-[1rem] bg-[radial-gradient(circle_at_18%_14%,rgba(183,205,194,0.22),transparent_36%),radial-gradient(circle_at_86%_82%,rgba(150,173,161,0.15),transparent_44%),linear-gradient(140deg,#22362d_0%,#18271f_52%,#141f1b_100%)] px-5 py-10 text-center shadow-[0_18px_40px_rgba(22,39,32,0.34)] md:px-10 md:py-14 lg:px-12">
          {(logoLight || logoDark) && <img src={logoLight || logoDark} alt="1896 logo" class="mx-auto mb-10 h-10 w-auto object-contain md:mb-14" />}
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[#efe4d7]">Before we end</p>
          <p class="mx-auto mt-4 max-w-5xl text-[1.02rem] leading-8 text-[#f4eadf]">Take a moment to pause. Think about your next interaction.</p>
          <h2 class="mx-auto mt-4 max-w-5xl text-[1.75rem] font-normal leading-[1.16] tracking-[0.005em] text-[#fffaf3] md:text-[1.9rem]">
            Not what you will say - but what you will notice.
          </h2>
          <p class="mx-auto mt-4 max-w-3xl text-[1.02rem] leading-8 text-[#f4eadf]">
            At 1896, the experience is shaped in small, considered moments.
          </p>
          <div class="mx-auto mt-8 grid max-w-5xl gap-4 md:grid-cols-3">
            {closingFocusStatements.map((item) => (
              <article class="tfg-flip-card min-h-[10rem] md:min-h-[10.75rem]" data-flip-card>
                <button type="button" class="tfg-flip-card-trigger min-h-[10rem] rounded-[0.95rem] border border-[#4c6157] md:min-h-[10.75rem]" data-flip-trigger aria-label={`Reveal: ${item}`}>
                  <span class="tfg-flip-card-inner">
                    <span class="tfg-flip-card-face tfg-flip-card-front bg-[linear-gradient(145deg,#4f675d_0%,#28342e_100%)]">
                      {logoLight || logoDark ? (
                        <img src={logoLight || logoDark} alt="1896 logo" class="h-10 w-auto object-contain md:h-12" />
                      ) : (
                        <span class="text-sm font-semibold uppercase tracking-[0.18em] text-[#fffaf3]">Logo</span>
                      )}
                    </span>
                    <span class="tfg-flip-card-face tfg-flip-card-back bg-[linear-gradient(145deg,#5a7368_0%,#32443c_100%)]">
                      <span class="text-[1.25rem] font-semibold leading-tight tracking-[-0.01em] text-[#fffaf3] md:text-[1.4rem]">
                        {item}
                      </span>
                    </span>
                  </span>
                </button>
              </article>
            ))}
          </div>
          <p class="mt-6 font-semibold italic text-[#f4eadf]">This is where the brand becomes real.</p>
          <p class="mt-6 text-[#f4eadf]">You are now ready to represent the 1896 brand.</p>
        </article>
      </section>

    </main>

    <script is:inline>
      const mobileNavs = document.querySelectorAll("[data-mobile-nav]");
      const flipCards = document.querySelectorAll("[data-flip-card]");

      document.addEventListener("click", (event) => {
        mobileNavs.forEach((menu) => {
          if (!menu.contains(event.target)) {
            menu.removeAttribute("open");
          }
        });

        flipCards.forEach((card) => {
          if (!card.contains(event.target)) {
            card.classList.remove("is-flipped");
          }
        });
      });

      mobileNavs.forEach((menu) => {
        menu.querySelectorAll("[data-mobile-nav-link]").forEach((link) => {
          link.addEventListener("click", () => {
            menu.removeAttribute("open");
          });
        });
      });

      const servicePillars = document.querySelectorAll("[data-service-pillar]");

      servicePillars.forEach((pillar) => {
        pillar.addEventListener("toggle", () => {
          if (!pillar.open) return;

          servicePillars.forEach((otherPillar) => {
            if (otherPillar !== pillar) {
              otherPillar.removeAttribute("open");
            }
          });
        });
      });

      flipCards.forEach((card) => {
        const trigger = card.querySelector("[data-flip-trigger]");
        if (!trigger) return;

        trigger.addEventListener("click", () => {
          card.classList.toggle("is-flipped");
        });
      });

      const lesson3OptionsContainer = document.querySelector("[data-kc3-options]");
      const lesson3OptionButtons = document.querySelectorAll("[data-kc3-option]");
      const lesson3Feedback = document.querySelector("[data-kc3-feedback]");

      if (lesson3OptionsContainer && lesson3OptionButtons.length > 0 && lesson3Feedback) {
        const correctAnswer = lesson3OptionsContainer.dataset.kc3Answer || "B";
        const feedbackCopy = lesson3OptionsContainer.dataset.kc3FeedbackCopy || "";

        lesson3OptionButtons.forEach((button) => {
          button.addEventListener("click", () => {
            const isCorrect = button.dataset.kc3Correct === "true";

            lesson3OptionButtons.forEach((otherButton) => {
              if (otherButton === button) {
                otherButton.setAttribute("data-kc3-state", isCorrect ? "correct" : "wrong");
                otherButton.setAttribute("aria-pressed", "true");
                return;
              }

              otherButton.setAttribute("data-kc3-state", "idle");
              otherButton.setAttribute("aria-pressed", "false");
            });

            lesson3Feedback.classList.remove("hidden");

            if (isCorrect) {
              lesson3Feedback.setAttribute("data-kc3-feedback-state", "correct");
              lesson3Feedback.textContent = `The best answer is ${correctAnswer}. ${feedbackCopy}`;
              return;
            }

            lesson3Feedback.setAttribute("data-kc3-feedback-state", "wrong");
            lesson3Feedback.textContent = "Try again.";
          });
        });
      }

      const lesson4OptionButtons = document.querySelectorAll("[data-l4-option]");
      const lesson4FeedbackByQuestion = new Map();

      document.querySelectorAll("[data-l4-feedback]").forEach((feedbackElement) => {
        lesson4FeedbackByQuestion.set(feedbackElement.dataset.l4Feedback, {
          element: feedbackElement,
          correctHtml: feedbackElement.innerHTML,
        });
      });

      lesson4OptionButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const questionId = button.dataset.l4Question;
          if (!questionId) return;

          const questionButtons = document.querySelectorAll(`[data-l4-question="${questionId}"]`);
          const isCorrect = button.dataset.l4Correct === "true";

          questionButtons.forEach((questionButton) => {
            if (questionButton === button) {
              questionButton.setAttribute("data-kc3-state", isCorrect ? "correct" : "wrong");
              questionButton.setAttribute("aria-pressed", "true");
              return;
            }

            questionButton.setAttribute("data-kc3-state", "idle");
            questionButton.setAttribute("aria-pressed", "false");
          });

          const feedbackEntry = lesson4FeedbackByQuestion.get(questionId);
          if (!feedbackEntry) return;

          feedbackEntry.element.classList.remove("hidden");

          if (isCorrect) {
            feedbackEntry.element.setAttribute("data-kc3-feedback-state", "correct");
            feedbackEntry.element.innerHTML = feedbackEntry.correctHtml;
            return;
          }

          feedbackEntry.element.setAttribute("data-kc3-feedback-state", "wrong");
          feedbackEntry.element.textContent = "Try again.";
        });
      });
    </script>
  </body>
</html>
